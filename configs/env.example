# OpenAI 兼容接口（用于 Embedding，示例：GLM / ZhipuAI）
# 例如：GLM Embedding 接口 https://open.bigmodel.cn/api/paas/v4/embeddings
# 则应设置为：
#   OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_API_KEY=please_fill_glm_embedding_key
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# DeepSeek Chat 接口（仅用于对话模型，不再自动回填到 OPENAI_*）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 数据与向量库路径（建议使用 data/WXhub 作为统一根目录）
# WXHUB_ROOT=F:\AIhub\WXdown-RAG\data\WXhub
# VECTOR_STORE_DIR=F:\AIhub\WXdown-RAG\storage\vector_store

# 可选：模型与 RAG 参数（不填则使用 configs/wxchatrag.json 中的默认值）
# EMBEDDING_MODEL_NAME=embedding-3
# CHAT_MODEL_NAME=deepseek-chat
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# RETRIEVER_K=5
# TEMPERATURE=0.2
