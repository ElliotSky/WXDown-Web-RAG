# ============================================================================
# 配置说明
# ============================================================================
# 本文件用于存放需要经常变动的或个人化的配置（如 API Key、路径等）
# 稳定的默认参数请查看 configs/wxchatrag.json
# 配置优先级：环境变量（本文件） > wxchatrag.json > 代码默认值

# ============================================================================
# API 配置（必填 - 个人化配置）
# ============================================================================

# 嵌入模型 API（用于文本向量化，FAISS向量库构建）
# 支持 OpenAI 兼容接口，例如：GLM 智谱、ZhipuAI、OpenAI 等
# GLM 智谱示例：
#   EMBEDDING_API_KEY=your_glm_api_key
#   EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# OpenAI 示例：
#   EMBEDDING_API_KEY=your_openai_api_key
#   EMBEDDING_BASE_URL=https://api.openai.com/v1
# 注意：
#   - 此API配置用于FAISS向量库构建（文本向量化）
#   - 语义切分（semantic chunking）默认使用本地BGE模型，也可通过 SEMANTIC_EMBEDDING_MODE=api 使用此API
EMBEDDING_API_KEY=please_fill_embedding_api_key
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 对话模型 API（用于生成回答）
# 支持 OpenAI 兼容接口，例如：DeepSeek、OpenAI、GLM 等
# DeepSeek 示例：
#   CHAT_API_KEY=your_deepseek_api_key
#   CHAT_BASE_URL=https://api.deepseek.com
# OpenAI 示例：
#   CHAT_API_KEY=your_openai_api_key
#   CHAT_BASE_URL=https://api.openai.com/v1
CHAT_API_KEY=
CHAT_BASE_URL=https://api.deepseek.com

# ============================================================================
# 数据路径配置（可选 - 个人化配置）
# ============================================================================
# 如果未设置，将使用 configs/wxchatrag.json 中的默认值

# 微信数据根目录（建议使用 data/WXhub 作为统一根目录）
# 相对路径会相对于项目根目录解析
# WXHUB_ROOT=data/WXhub

# 向量库持久化目录
# VECTOR_STORE_DIR=storage/vector_store

# BM25 索引目录
# BM25_INDEX_DIR=storage/bm25_index

# 模型缓存目录（用于 Rerank 等本地模型）
# MODELS_CACHE_DIR=storage/models

# ============================================================================
# 模型配置（可选 - 个人化配置）
# ============================================================================
# 如果未设置，将使用 configs/wxchatrag.json 中的默认值

# 嵌入模型名称（用于文本向量化，FAISS向量库构建）
# GLM 智谱使用：embedding-3
# OpenAI 使用：text-embedding-3-large
# EMBEDDING_MODEL_NAME=embedding-3
#
# 语义切分embedding配置
# SEMANTIC_EMBEDDING_MODE: 语义切分embedding模式
#   - "local"（默认）：使用本地部署的BGE模型（北京智源研究院）
#   - "api"：使用标准API接口（支持GLM、OpenAI等，需要配置EMBEDDING_API_KEY）
# SEMANTIC_EMBEDDING_MODE=local
#
# SEMANTIC_EMBEDDING_MODEL_NAME: 语义切分embedding模型名称
#   当 SEMANTIC_EMBEDDING_MODE=local 时，支持的BGE模型：
#     - BAAI/bge-large-zh-v1.5（中文大模型，推荐）
#     - BAAI/bge-base-zh-v1.5（中文基础模型）
#     - BAAI/bge-small-zh-v1.5（中文小模型，默认，速度快）
#     - BAAI/bge-large-en-v1.5（英文大模型）
#     - BAAI/bge-base-en-v1.5（英文基础模型）
#   当 SEMANTIC_EMBEDDING_MODE=api 时，使用API模型名称（如 embedding-3、text-embedding-3-large）
# SEMANTIC_EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
#
# SEMANTIC_SENTENCE_SPLIT_MODE: 语义切分分句模式
#   - "mixed"（默认）：同时支持中文标点、英文标点和换行
#   - "chinese"：仅按中文标点和换行分句
#   - "english"：沿用 LangChain 默认英文分句规则
#   - "custom"：使用 SEMANTIC_SENTENCE_SPLIT_REGEX 中的自定义正则
# SEMANTIC_SENTENCE_SPLIT_MODE=mixed
#
# SEMANTIC_SENTENCE_SPLIT_REGEX: 自定义语义分句正则
#   - 当 SEMANTIC_SENTENCE_SPLIT_MODE=custom 时建议显式设置
#   - 非 custom 模式下，如果这里有值，也会优先使用该值覆盖内置规则
#   - mixed 模式内置规则同时兼容中文/英文标点与换行
# 例子：
#   SEMANTIC_SENTENCE_SPLIT_REGEX=(?<=[。！？；])|(?<=[.?!])\\s+|\\n+
# SEMANTIC_SENTENCE_SPLIT_REGEX=

# 对话模型名称（用于生成回答）
# DeepSeek 使用：deepseek-chat
# OpenAI 使用：gpt-4 或 gpt-3.5-turbo
# CHAT_MODEL_NAME=deepseek-chat

# ============================================================================
# PDF 数据源配置（可选 - 个人化配置）
# ============================================================================

# PDF 子目录名称（每个公众号目录下的 PDF 存放目录）
# PDF_SUBDIR_NAME=pdf

# PDF 文件匹配模式（glob 模式，为空时默认使用 */{PDF_SUBDIR_NAME}/*.pdf）
# PDF_GLOB_PATTERN=

# ============================================================================
# 其他可选配置（可选 - 个人化配置）
# ============================================================================
# 以下配置如果未设置，将使用 configs/wxchatrag.json 中的默认值
# 如需覆盖默认值，可在此处设置

# 文档切分配置
# CHUNK_SIZE: 块大小（字符数），对所有切分策略都有效
#   对于语义切分（semantic），CHUNK_SIZE 会被用作 min_chunk_size（最小块大小）
#   语义切分会根据语义相似度自动切分，但会确保块不小于 min_chunk_size
# CHUNK_SIZE=1000
# CHUNK_OVERLAP: 块之间的重叠大小（字符数），仅对非语义切分策略有效
#   语义切分通常不重叠，所以此参数对语义切分无效
# CHUNK_OVERLAP=200
# CHUNK_STRATEGY: 切分策略
#   - fixed: 固定大小切分（RecursiveCharacterTextSplitter）
#   - sentence: 基于句子的切分
#   - semantic: 语义切分（基于嵌入相似度，使用 min_chunk_size）
#   - hierarchical: 层次化切分（先段落后句子）
#   - sliding_window: 滑动窗口切分
# CHUNK_STRATEGY=fixed
# SEMANTIC_THRESHOLD: 语义切分阈值（仅语义切分需要）
#   相似度低于此值则切分，范围通常为 0.0-1.0
# SEMANTIC_THRESHOLD=0.5

# RAG 检索配置
# RETRIEVER_K=5
# TEMPERATURE=0.2

# 混合检索配置
# RETRIEVAL_STRATEGY=hybrid  # vector | bm25 | hybrid
# HYBRID_ALPHA=0.7
# BM25_K=20
# VECTOR_K=20

# 重排序配置
# ENABLE_RERANK=true
# RERANK_MODEL_NAME=BAAI/bge-reranker-base
# RERANK_TOP_N=20
# RERANK_TOP_K=5
# RERANK_BATCH_SIZE=16
# RERANK_DEVICE=cpu  # cpu | cuda

# ============================================================================
# 其他配置（可选）
# ============================================================================

# 自定义配置文件路径（默认：configs/wxchatrag.json）
# WXCHATRAG_CONFIG_PATH=configs/wxchatrag.json
